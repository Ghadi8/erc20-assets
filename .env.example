RPC_URL=
GET_ASSETS_TEST_ADDRESS=
# Optional. Factory/implementation contract whose deployment block becomes the
# default fromBlock for discovery. No wallet can exist before it was deployed. (specific to JAW logic)
ANCHOR_CONTRACT=0x5803c076563C85799989d42Fc00292A8aE52fa9E
# Optional overrides. FROM_BLOCK takes precedence over ANCHOR_CONTRACT.
# FROM_BLOCK=
# Max block span per eth_getLogs request. Larger = fewer requests but higher
# chance the provider refuses; the client bisects on refusal. Testnet RPCs
# usually need a smaller value (e.g. 10000–50000) than mainnets (up to 1000000).
# MAX_LOG_RANGE=
# Parallel eth_getLogs requests during discovery. Public RPCs tolerate ~5,
# paid mainnet endpoints often 20–50. Lower on testnets.
# DISCOVER_CONCURRENCY=
